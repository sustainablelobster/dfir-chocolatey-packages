    <title>SIFT Workstation (WSL)</title>
    <authors>Harbingers LLC, Rob Lee, SANS Institute</authors>
    <projectUrl>https://www.sans.org/tools/sift-workstation/</projectUrl>
    <!--<iconUrl>http://rawcdn.githack.com/__REPLACE_YOUR_REPO__/master/icons/wsl-sift-workstation.png</iconUrl>-->
